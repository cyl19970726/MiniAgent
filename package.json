{
  "name": "@continue-reasoning/mini-agent",
  "version": "0.1.6",
  "type": "module",
  "private": false,
  "description": "A platform-agnostic AI agent framework for building autonomous AI agents with tool execution capabilities",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "example": "npx tsx examples/basicExample.ts",
    "example:basic": "npx tsx examples/basicExample.ts",
    "example:gemini": "npx tsx examples/basicExample.ts --gemini",
    "example:openai": "npx tsx examples/openaiExample.ts",
    "example:openai-basic": "npx tsx examples/basicExample.ts --openai",
    "example:openai-response": "npx tsx examples/basicExample.ts --openairep",
    "example:all": "npx tsx examples/basicExample.ts --all",
    "example:comparison": "npx tsx examples/providerComparison.ts",
    "example:weather": "npx tsx examples/weatherExample.ts",
    "demo": "npx tsx examples/demoExample.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:tools": "vitest run src/test/examples/tools.test.ts",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@google/genai": "^1.8.0",
    "dotenv": "^16.4.5",
    "openai": "^5.10.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@vitest/coverage-v8": "^1.3.1",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./interfaces": {
      "types": "./dist/interfaces.d.ts",
      "import": "./dist/interfaces.js",
      "require": "./dist/interfaces.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "keywords": [
    "ai",
    "agent",
    "autonomous",
    "framework",
    "llm",
    "tools",
    "gemini",
    "openai",
    "platform-agnostic"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cyl19970726/Agent.git",
    "directory": "packages/agent"
  },
  "bugs": {
    "url": "https://github.com/cyl19970726/Agent/issues"
  },
  "homepage": "https://github.com/cyl19970726/Agent#readme",
  "author": "Agent Framework Contributors",
  "license": "Apache-2.0"
}
